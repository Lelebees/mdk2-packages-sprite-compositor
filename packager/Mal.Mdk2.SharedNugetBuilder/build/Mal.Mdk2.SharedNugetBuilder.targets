<Project>
  
  <Target Name="MdkPackageSharedProjects" AfterTargets="Build" Condition="('$(Configuration)' == 'Release' OR '$(Configuration)' == 'Debug') AND '$(MdkDisableAutoPackage)' != 'true'">
    <PropertyGroup>
      <!-- Detect OS and set appropriate path -->
      <MdkPackagerRid Condition="$([MSBuild]::IsOSPlatform('Windows'))">win-x64</MdkPackagerRid>
      <MdkPackagerRid Condition="$([MSBuild]::IsOSPlatform('Linux'))">linux-x64</MdkPackagerRid>
      
      <MdkPackagerExe Condition="$([MSBuild]::IsOSPlatform('Windows'))">Mal.Mdk2.SharedNugetBuilder.exe</MdkPackagerExe>
      <MdkPackagerExe Condition="$([MSBuild]::IsOSPlatform('Linux'))">Mal.Mdk2.SharedNugetBuilder</MdkPackagerExe>
      
      <MdkPackagerPath>$(MSBuildThisFileDirectory)..\tools\net8.0\$(MdkPackagerRid)\$(MdkPackagerExe)</MdkPackagerPath>
      
      <!-- Build command with optional flags -->
      <MdkPackagerArgs>--demo "$(MSBuildProjectFullPath)"</MdkPackagerArgs>
      <MdkPackagerArgs Condition="'$(Configuration)' == 'Debug'">$(MdkPackagerArgs) --dry-run</MdkPackagerArgs>
      <MdkPackagerArgs Condition="'$(MdkAutoBumpVersion)' == 'true'">$(MdkPackagerArgs) --auto-bump</MdkPackagerArgs>
      <MdkPackagerArgs Condition="'$(MdkForceRebuild)' == 'true'">$(MdkPackagerArgs) --force</MdkPackagerArgs>
    </PropertyGroup>
    
    <Message Text="MDK Shared Project Packager: Packaging shared projects..." Importance="high" />
    
    <Exec Command="&quot;$(MdkPackagerPath)&quot; $(MdkPackagerArgs)" 
          IgnoreExitCode="false"
          WorkingDirectory="$(MSBuildProjectDirectory)"
          ConsoleToMSBuild="true">
      <Output TaskParameter="ConsoleOutput" ItemName="PackagerOutput" />
    </Exec>
    
    <!-- Output packager messages as MSBuild messages for IDE integration -->
    <Message Text="%(PackagerOutput.Identity)" Importance="high" />
  </Target>

</Project>
